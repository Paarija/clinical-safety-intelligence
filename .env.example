# Local development example. `python3 -m clinical_safety.init_env` may copy
# this file to `.env` when `.env` is missing; it does not fill secret values.
# Production deployments should source secrets from a managed secret store
# (Vault, AWS/GCP/Azure secret manager, or equivalent) and inject them into
# the service process through the supervisor. Do not commit real keys here.

# Required for real Gemini LLM runs; set manually. Leave blank only for
# dry-run/mock workflows.
GEMINI_API_KEY=

# Optional (increases PubMed rate limit from 3 to 10 req/s)
# NCBI_API_KEY=your_ncbi_api_key_here

# Logging
LOG_LEVEL=INFO
# LOG_FORMAT=json

# Data directory (override default ./data)
# DATA_DIR=/absolute/path/to/data

# LangGraph checkpoint storage (optional; requires langgraph-checkpoint-sqlite)
# CHECKPOINT_DIR=./data/processed/checkpoints
